/*! \brief Does autoloading for classes used in GOsa.
 *
 *  Takes the list generated by 'update-gosa' and loads the
 *  file containing the requested class.
 *
 *  \param  string 'class_name' The currently requested class
 */
function __gosa_autoload($class_name)
{
    global $class_mapping, $BASE_DIR;

    if ($class_mapping === NULL) {
        echo sprintf(_('Fatal error: no class locations defined - please run %s to fix this'), bold('update-gosa'));
        exit;
    }

    if (preg_match('/^Smarty_.*/', $class_name)) {
        return;
    }

    if (count(explode("\\", $class_name)) > 1) {
        $classPath = explode("\\", $class_name);
        $class_name = end($classPath);
    }

    if (isset($class_mapping["$class_name"])) {
        require_once($BASE_DIR . "/" . $class_mapping["$class_name"]);
    } else {
        echo sprintf(_('Fatal error: cannot instantiate class %s - try running %s to fix this'), bold($class_name), bold('update-gosa'));
        exit;
    }
}

spl_autoload_register('__gosa_autoload');

function format_stacktrace(array $trace): array {
    $formatted = [];
    
    foreach ($trace as $index => $entry) {
        $frameData = [
            'index' => $index,
            'file' => $entry['file'] ?? null,
            'line' => $entry['line'] ?? null,
            'function' => $entry['function'] ?? null,
            'class' => $entry['class'] ?? null,
            'type' => $entry['type'] ?? null,
            'args' => []
        ];
        
        // Handle args
        if (isset($entry['args'])) {
            foreach ($entry['args'] as $arg) {
                $frameData['args'][] = is_scalar($arg) || is_null($arg)
                    ? var_export($arg, true)
                    : (is_array($arg)
                        ? 'Array(' . count($arg) . ')'
                        : 'Object(' . get_class($arg) . ')');
            }
        }
        
        $formatted[] = $frameData;
    }
    
    return $formatted;
}

function gosaRaiseError($errno, $errstr, $errfile, $errline)
{
    global $error_collector, $config;

    // To avoid recursion - restore original error handler.
    restore_error_handler();

    /* Return if error reporting is set to zero 
   * Also exclude statements prefixed with @ - Comment out the block below to see suppressed errors. 
   * e.g. @call_function_but_hide_errors()
   */
    if (error_reporting() == 0) {
        set_error_handler('gosaRaiseError', E_WARNING |  E_NOTICE | E_USER_ERROR | E_USER_WARNING | E_USER_NOTICE);
        return;
    }

    /* Workaround for buggy imap_open error outputs */
    if (preg_match('/imap_open/', $errstr)) {
        set_error_handler('gosaRaiseError', E_WARNING |  E_NOTICE | E_USER_ERROR | E_USER_WARNING | E_USER_NOTICE);
        return;
    }

    /* Hide ldap size limit messages */
    if (preg_match('/ldap_error/', $errstr)) {
        if (preg_match('/sizelimit/', $errstr)) {
            set_error_handler('gosaRaiseError', E_WARNING |  E_NOTICE | E_USER_ERROR | E_USER_WARNING | E_USER_NOTICE);
            return;
        }
    }

    /* Error messages are hidden in GOsa, so we only send them to the logging class and abort here */
    if (isset($config->data) && $config->get_cfg_value('core', 'displayErrors') != "true") {

        /* Write to syslog */
        if (class_exists("log") && !preg_match("/No such object/", $errstr)) {
            new log("view", "error", "", array(), "PHP error: $errstr ($errfile, line $errline)");
        }

        set_error_handler('gosaRaiseError', E_WARNING |  E_NOTICE | E_USER_ERROR | E_USER_WARNING | E_USER_NOTICE);
        return;
    }

    /* Send all errors to logging class, except "Ldap : No such object" messages*/
    if (class_exists("log") && !preg_match("/No such object/", $errstr)) {
        new log("debug", "all", $errfile, array(), "Type:" . $errno . ", Message:" . $errstr . ", File:" . $errfile . ", Line: " . $errline);
    }

    // Log errors in usage DB
    if (class_exists('stats') && !preg_match("/No such object/", $errstr)) {
        stats::log(
            'error',
            $class = 'ERROR',
            $category = array(),
            $action = __FUNCTION__,
            $amount = 1,
            $duration = 0,
            $errno
        );
    }

    /* Extract traceback data - if available */
    if (function_exists('debug_backtrace')) {
        $trace = debug_backtrace();        
    }

    if (function_exists("get_gosa_version")) {
        $error_collector['version'] = get_gosa_version();
    } else {
        $error_collector['version'] = 'unknown';
    }

    $error_collector['items'][] = [
        'errstr'    => $errstr,
        'errfile'   => $errfile,
        'errline'   => $errline,
        'trace'     => format_stacktrace($trace),
    ];
}


function prepare4mailbody($string)
{
    $string = html_entity_decode($string);

    $from = array(
        "/%/",
        "/ /",
        "/\n/",
        "/\r/",
        "/!/",
        "/#/",
        "/\*/",
        "/\//",
        "/</",
        "/>/",
        "/\?/",
        "/\"/"
    );

    $to = array(
        "%25",
        "%20",
        "%0A",
        "%0D",
        "%21",
        "%23",
        "%2A",
        "%2F",
        "%3C",
        "%3E",
        "%3F",
        "%22"
    );

    $string = preg_replace($from, $to, $string);

    return ($string);
}


